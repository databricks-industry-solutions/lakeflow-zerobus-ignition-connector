# Set once; used by Makefile and all scripts.
# Source before make:  set -a && source .env && set +a
# Or export these in your shell.

# Databricks SDK / app: profile for ~/.databrickscfg and warehouse for Statement Execution
# Used by app backend, integration tests (demo/app), and SDK scripts when profile is set.
DATABRICKS_CONFIG_PROFILE=daveok
DATABRICKS_WAREHOUSE_ID=e4082fdb7ea19a15
# When using profile auth: host must match the URL you used for "databricks auth login --host <url>".
# Unset or omit to use the host from the profile; set to match your workspace (e.g. .11 not .10).
# DATABRICKS_HOST=https://adb-7405609621983921.1.azuredatabricks.net

# Workspace identity (ZEROBUS_ENDPOINT is derived as <WORKSPACE_ID>.zerobus.<DATABRICKS_REGION>.azuredatabricks.net if unset)
WORKSPACE_ID=7405609621983921
DATABRICKS_REGION=australiaeast
# Optional: set ZEROBUS_ENDPOINT explicitly to override the derived value
# ZEROBUS_ENDPOINT=7405609621983921.zerobus.australiaeast.azuredatabricks.net

# Optional overrides (Makefile defaults shown)
# CATALOG=ot_demo
# SCHEMA=ot
SP_PROFILE_NAME=ot-demo

# PostgreSQL (Lakebase) settings - for app backend + Ignition gateway PostgreSQL sink
# LAKEBASE_HOST=ep-xxx.databricks.com
# LAKEBASE_PORT=5432
# LAKEBASE_DATABASE=databricks_postgres
# LAKEBASE_USER=role_name
# LAKEBASE_PASSWORD=your_password
# LAKEBASE_TABLE=raw_tags
