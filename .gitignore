# Maven (if used)
target/
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
dependency-reduced-pom.xml

# Package Files
*.zip
!gradle-wrapper.jar

# Module Signing Keys
*.p12
*.jks
keystore

my-config.json
#
# JSON
# We ignore JSON by default to reduce the risk of accidentally committing credentials/config dumps.
# Demo assets (tag exports, notebook presets, dashboard definitions) live under examples/tools/sources,
# so we explicitly allow JSON in those directories.
*.json
!examples/**/*.json
!pipelines/**/*.json
!sources/**/*.json
!demo/simulator/**/*.json
!demo/app/**/*.json
!demo/package.json
!demo/package-lock.json

# Node.js
node_modules/
dist/

# App build artifacts
demo/app/static/

# Local-only Ignition backups (do not commit)
onboarding/ignition/**/backup_ignition81/

# Gateway backups (do not commit)
*.gwbk

# Local docker/colima env files (may contain credentials)
*.env
!.env.example
!demo/.env.example

# Tools cloned/built locally (do not commit)
pipelines/module-signer/

# Docker-based build outputs (do not commit)
docker-out/
# Local generated/backup config files (do not commit)
module/src/main/resources/zerobus.properties*

# Local-only demo artifacts (do not commit)
AGL_Tomago_Demo_Talk_Track.pdf
pipelines/tmp_agl_logo.svg

# AVEVA / partner-sensitive (repo is public — do not commit competitive or internal analysis)
AVEVA_PI_ASSET_INTELLIGENCE_GAP_ANALYSIS.md
AGL_DATABRICKS_VS_HISTORIAN_POSITION.md
AGL_DATABRICKS_VS_HISTORIAN_POSITION_V2.md
AGL_REPLY_TO_RATISH_DRAFT.md
IT_OT_DIFFERENTIATORS.md

# git-filter-repo replace-text rules (local use only; do not commit)
replace-text-rules.txt
# Databricks 101 session materials (not for public repo)
databricks_101_session_plan.md
databricks_101_presentation.html
