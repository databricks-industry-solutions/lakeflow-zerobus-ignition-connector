# Databricks connection (required)
DATABRICKS_HOST=https://adb-xxxx.azuredatabricks.net
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/xxxxxxxxxxxxxxxx

# Authentication - use ONE of these methods:
# Option 1: PAT token (local development)
DATABRICKS_TOKEN=dapiXXXXXXXXXXXXXXXX
# Option 2: Service principal (Databricks Apps - auto-injected)
# DATABRICKS_CLIENT_ID=your-client-id
# DATABRICKS_CLIENT_SECRET=your-client-secret

# SQL warehouse ID (auto-injected by Databricks Apps via app.yaml valueFrom)
# DATABRICKS_WAREHOUSE_ID=your-warehouse-id

# Databricks catalog and schema (defaults shown)
DATABRICKS_CATALOG=ot_demo
DATABRICKS_SCHEMA=ot

# Zerobus ingestion
# Endpoint format: <workspace-id>.zerobus.<region>.azuredatabricks.net (Azure)
#                  <workspace-id>.zerobus.<region>.cloud.databricks.com (AWS)
# The workspace ID is the numeric part from your workspace URL (e.g. adb-123... -> 123...)
ZEROBUS_ENDPOINT=your-workspace-id.zerobus.your-region.azuredatabricks.net
ZEROBUS_CLIENT_ID=your-service-principal-application-id
ZEROBUS_CLIENT_SECRET=your-service-principal-secret
# Target table should match DATABRICKS_CATALOG.DATABRICKS_SCHEMA.raw_tags
ZEROBUS_TABLE=${DATABRICKS_CATALOG}.${DATABRICKS_SCHEMA}.raw_tags

# Swinging Door Trending defaults
SDT_DEFAULT_COMP_DEV_PERCENT=1.0
SDT_DEFAULT_COMP_MAX_SECONDS=600
